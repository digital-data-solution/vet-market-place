# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/vet_app

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Payments (Paystack) ───────────────────────────────────────────────────────
PAYSTACK_SECRET=your_paystack_secret_key
PAYSTACK_CALLBACK_URL=https://yourdomain.com/paystack/callback
PAYSTACK_BASE=https://api.paystack.co

# ── Email — set ONE of these to enable transactional email ───────────────────
# Option A: Resend (resend.com) — create a free account, add your domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Option B: Brevo (brevo.com) — free tier: 300 emails/day
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender address — must be a verified domain in your chosen provider
EMAIL_FROM=Xpress Vet <noreply@yourdomain.com.ng>
# Admin email — receives new verification requests
ADMIN_EMAIL=admin@yourdomain.com.ng

# ── Media (Cloudinary) ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Push Notifications (OneSignal) ────────────────────────────────────────────
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
# TLS (production):  rediss://:<password>@host:port
# Non-TLS (local):   redis://localhost:6379
REDIS_URL=redis://localhost:6379
